{
  "name": "@mst-mkt/mixi2-application-sdk-ts",
  "version": "0.1.0",
  "description": "mixi2 Application SDK for TypeScript (Unofficial)",
  "keywords": [
    "mixi2"
  ],
  "homepage": "https://github.com/mst-mkt/mixi2-application-sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/mst-mkt/mixi2-application-sdk-ts/issues"
  },
  "license": "Apache-2.0",
  "author": "mst-mkt",
  "repository": {
    "type": "git",
    "url": "https://github.com/mst-mkt/mixi2-application-sdk-ts.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./event": {
      "types": "./dist/event/index.d.ts",
      "import": "./dist/event/index.js"
    },
    "./event/webhook": {
      "types": "./dist/event/webhook/index.d.ts",
      "import": "./dist/event/webhook/index.js"
    },
    "./event/stream": {
      "types": "./dist/event/stream/index.d.ts",
      "import": "./dist/event/stream/index.js"
    }
  },
  "scripts": {
    "generate": "buf generate",
    "build": "tsdown",
    "check:lint": "oxlint",
    "check:fmt": "oxfmt --check",
    "check:types": "tsc --noEmit",
    "fix:lint": "oxlint --fix",
    "fix:fmt": "oxfmt",
    "test": "vitest run",
    "test:watch": "vitest",
    "prerelease": "pnpm build",
    "release": "changeset publish",
    "version": "changeset version",
    "postversion": "node ./scripts/sync-jsr-version.ts"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@connectrpc/connect": "^2.1.1",
    "@types/node": "^24.12.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.7.0",
    "@connectrpc/connect": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.3.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf"
    ]
  }
}
